rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Campaigns Collection
    match /campaigns/{campaignId} {
      // Allow get (single document) if user is a member
      allow get: if isSignedIn() && 
                    request.auth.uid in resource.data.members;
      
      // Allow list (queries) for authenticated users
      // Client must filter with where('members', 'array-contains', uid)
      allow list: if isSignedIn();
      
      // Allow create if user is authenticated
      // User must include themselves in members array
      allow create: if isSignedIn() && 
                       request.auth.uid in request.resource.data.members &&
                       request.resource.data.members.size() == 1 &&
                       request.resource.data.createdBy == request.auth.uid;
      
      // Allow update if user is a member
      // Members can update name, add new members, or remove themselves
      allow update: if isSignedIn() && 
                       request.auth.uid in resource.data.members &&
                       (
                         // Allow name updates
                         (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'updatedAt'])) ||
                         // Allow adding new members
                         (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberDetails', 'updatedAt']) &&
                          request.resource.data.members.size() > resource.data.members.size()) ||
                         // Allow removing themselves
                         (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberDetails', 'updatedAt']) &&
                          request.resource.data.members.size() < resource.data.members.size() &&
                          !(request.auth.uid in request.resource.data.members))
                       );
      
      // Allow delete if user is the last member
      allow delete: if isSignedIn() && 
                       resource.data.members.size() == 1 && 
                       request.auth.uid in resource.data.members;
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
